<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!--
        SurfaceView Android standard. Il Surface viene passato al
        VulkanRenderer (path Vulkan) o, in fallback, a CameraHelper.addSurface
        (path UVC legacy). La logica di aspect/rotation/mirror e' in
        AspectController.kt + compute shader Vulkan, non piu' nella view.
    -->
    <SurfaceView
        android:id="@+id/cameraView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- gradient sopra per leggibilità top bar -->
    <View
        android:id="@+id/topGradient"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_top_gradient" />

    <!-- top bar overlay: titolo + bottoni -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:fitsSystemWindows="true">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_camera"
            android:contentDescription="@string/app_name"
            android:tint="@color/on_surface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3"
            android:singleLine="true"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btnEv"
            style="@style/Widget.UsbCamera.IconButton"
            android:src="@drawable/ic_brightness"
            android:contentDescription="@string/action_ev"
            android:visibility="gone"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnSnapshot"
            style="@style/Widget.UsbCamera.IconButton"
            android:src="@drawable/ic_snapshot"
            android:contentDescription="@string/action_snapshot"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnInfo"
            style="@style/Widget.UsbCamera.IconButton"
            android:src="@drawable/ic_info"
            android:contentDescription="@string/action_info"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            style="@style/Widget.UsbCamera.IconButton"
            android:src="@drawable/ic_settings"
            android:contentDescription="@string/action_settings" />
    </LinearLayout>

    <!-- hint centrale con eventuali pulsanti azione -->
    <LinearLayout
        android:id="@+id/hintBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_hint_pill"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_connect"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:gravity="center"
            tools:text="Collega webcam via OTG" />

        <LinearLayout
            android:id="@+id/hintActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_retry"
                android:textColor="@color/on_surface"
                android:background="@drawable/bg_action_button"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnGrant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_grant_permission"
                android:textColor="@color/on_surface"
                android:background="@drawable/bg_action_button"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnAppSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_open_settings"
                android:textColor="@color/on_surface"
                android:background="@drawable/bg_action_button"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- badge nome camera in basso a sinistra -->
    <LinearLayout
        android:id="@+id/camBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_cam_badge"
        android:visibility="gone"
        android:fitsSystemWindows="true">

        <View
            android:id="@+id/camBadgeDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/dot_status" />

        <TextView
            android:id="@+id/camBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cam_unknown"
            android:textColor="@color/on_surface"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxWidth="220dp" />
    </LinearLayout>

    <!-- Pannello controlli immagine: 3 slider verticali + reset -->
    <LinearLayout
        android:id="@+id/evPanel"
        android:layout_width="wrap_content"
        android:layout_height="320dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_cam_badge"
        android:visibility="gone"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

        <!-- Luminosità -->
        <LinearLayout
            android:id="@+id/colBrightness"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ev_brightness"
                android:textColor="@color/on_surface_muted"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/evSeekBrightness"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:rotation="270"
                android:layout_marginTop="100dp"
                android:layout_marginBottom="100dp"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/brand_accent"
                android:thumbTint="@color/brand_accent" />

            <TextView
                android:id="@+id/evValueBrightness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:textColor="@color/on_surface"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Contrasto -->
        <LinearLayout
            android:id="@+id/colContrast"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ev_contrast"
                android:textColor="@color/on_surface_muted"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/evSeekContrast"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:rotation="270"
                android:layout_marginTop="100dp"
                android:layout_marginBottom="100dp"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/brand_accent"
                android:thumbTint="@color/brand_accent" />

            <TextView
                android:id="@+id/evValueContrast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:textColor="@color/on_surface"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Esposizione -->
        <LinearLayout
            android:id="@+id/colExposure"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ev_exposure"
                android:textColor="@color/on_surface_muted"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/evSeekExposure"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:rotation="270"
                android:layout_marginTop="100dp"
                android:layout_marginBottom="100dp"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/brand_accent"
                android:thumbTint="@color/brand_accent" />

            <TextView
                android:id="@+id/evValueExposure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:textColor="@color/on_surface"
                android:textSize="11sp" />
        </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnEvReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ev_reset"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:minHeight="36dp"
            android:background="@drawable/bg_action_button" />
    </LinearLayout>

    <!-- Settings panel laterale -->
    <ScrollView
        android:id="@+id/settingsPanel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/bg_settings_panel"
        android:fillViewport="true"
        android:visibility="gone"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_title"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnCloseSettings"
                    style="@style/Widget.UsbCamera.IconButton"
                    android:src="@drawable/ic_close"
                    android:contentDescription="@string/action_close" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@color/divider" />

            <!-- Sezione Video -->
            <TextView style="@style/SectionHeader" android:text="@string/settings_section_video" />

            <TextView style="@style/SettingLabel" android:text="@string/setting_resolution" />
            <Spinner android:id="@+id/spResolution" style="@style/SettingSpinner" />

            <TextView style="@style/SettingLabel" android:text="@string/setting_fps" />
            <Spinner android:id="@+id/spFps" style="@style/SettingSpinner" />

            <!-- Sezione View -->
            <TextView style="@style/SectionHeader" android:text="@string/settings_section_view" />

            <TextView style="@style/SettingLabel" android:text="@string/setting_aspect" />
            <Spinner android:id="@+id/spAspect" style="@style/SettingSpinner" />

            <TextView style="@style/SettingLabel" android:text="@string/setting_rotation" />
            <Spinner android:id="@+id/spRotation" style="@style/SettingSpinner" />

            <CheckBox android:id="@+id/cbMirrorH"
                style="@style/SettingCheck"
                android:text="@string/setting_mirror_h" />

            <CheckBox android:id="@+id/cbMirrorV"
                style="@style/SettingCheck"
                android:text="@string/setting_mirror_v" />

            <!-- Sezione App -->
            <TextView style="@style/SectionHeader" android:text="@string/settings_section_app" />

            <TextView style="@style/SettingLabel" android:text="@string/setting_orientation" />
            <Spinner android:id="@+id/spOrientation" style="@style/SettingSpinner" />

            <CheckBox android:id="@+id/cbKeepScreen"
                style="@style/SettingCheck"
                android:text="@string/setting_keep_screen_on" />

            <CheckBox android:id="@+id/cbHideUiAuto"
                style="@style/SettingCheck"
                android:text="@string/setting_hide_ui_auto" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/reset_defaults"
                android:textColor="@color/on_surface"
                android:background="@drawable/bg_action_button" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
